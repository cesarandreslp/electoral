{
  "name": "@campaignos/db",
  "version": "0.1.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "db:push": "dotenv -e ../../.env -- prisma db push --schema=./prisma/schema.prisma",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev --schema=./prisma/schema.prisma",
    "db:seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "db:studio": "dotenv -e ../../.env -- prisma studio --schema=./prisma/schema.prisma",
    "db:create-superadmin": "dotenv -e ../../.env -- tsx src/create-superadmin.ts",
    "generate": "prisma generate --schema=./prisma/schema.prisma"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10",
    "@prisma/adapter-neon": "^6",
    "@prisma/client": "^6",
    "bcryptjs": "^2",
    "prisma": "^6",
    "ws": "^8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2",
    "@types/ws": "^8",
    "dotenv": "^7",
    "tsx": "^4",
    "typescript": "^5"
  }
}
