// Prisma schema — CampaignOS
// Documentación: https://pris.ly/d/prisma-schema
//
// TODO: En una versión futura, separar en dos archivos:
//   - prisma/superadmin.schema.prisma  → modelos del panel de administración
//   - prisma/tenant.schema.prisma      → modelos de cada campaña (tenant)
// Por ahora ambos conjuntos de modelos conviven en este único schema.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  // DATABASE_URL es el estándar de Prisma para comandos CLI (migrate dev, migrate deploy, studio)
  // El cliente de runtime en src/index.ts usa DATABASE_URL_SUPERADMIN directamente (ver Pool constructor)
  url      = env("DATABASE_URL")
}

// ─── ENUMERACIONES ────────────────────────────────────────────────────────────

/// Roles del sistema. Define qué rutas y datos puede acceder cada usuario.
enum UserRole {
  SUPERADMIN    // Acceso total a la plataforma y todos los tenants
  ADMIN_CAMPANA // Administrador de una campaña específica
  COORDINADOR   // Coordinador de zona o municipio
  LIDER         // Líder comunitario con red de electores
  TESTIGO       // Testigo electoral en mesa de votación
}

/// Estado de compromiso de voto de un elector — funnel de contacto
enum CommitmentStatus {
  SIN_CONTACTAR  // Aún no se ha hecho ningún contacto
  CONTACTADO     // Se hizo contacto pero sin posición definida
  SIMPATIZANTE   // Muestra interés positivo en la campaña
  COMPROMETIDO   // Ha prometido su voto
  VOTO_SEGURO    // Compromiso firme y confirmado
}

/// Tipo de división político-administrativa
enum CommuneType {
  COMUNA         // Zona urbana
  CORREGIMIENTO  // Zona rural
}

/// Estado operativo de un líder en la campaña
enum LeaderStatus {
  ACTIVO     // Operando normalmente
  INACTIVO   // Temporalmente fuera de operación
  SUSPENDIDO // Suspendido de la campaña
}

// ─── MODELOS SUPERADMIN ───────────────────────────────────────────────────────
// Estos modelos viven en la DB del superadmin y gestionan la plataforma.

/// Tenant = una campaña electoral registrada en la plataforma.
/// Cada tenant tiene su propia base de datos aislada en Neon.
model Tenant {
  id       String  @id @default(cuid())
  slug     String  @unique // Identificador URL amigable (ej: "campana-gomez-2026")
  name     String          // Nombre visible de la campaña
  domain   String? @unique // Dominio propio del cliente (opcional)
  // CIFRADO: este campo se cifra con AES-256 antes de persistir. Ver lib/crypto.ts
  connectionString String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  modules TenantModule[]
}

/// Módulos activos para cada tenant. Se inyectan en la sesión del usuario.
/// Los módulos inactivos no son accesibles aunque el usuario intente la ruta.
model TenantModule {
  id        String  @id @default(cuid())
  tenantId  String
  moduleKey String  // Ej: "CORE", "ANALYTICS", "DIA_E", "FORMACION", etc.
  isActive  Boolean @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, moduleKey])
}

/// Material global de formación gestionado desde el panel superadmin.
/// Se almacena en Vercel Blob bajo formacion/global/{filename}.
/// Los tenants con módulo FORMACION activo pueden ver estos materiales,
/// y opcionalmente ocultarlos o reordenarlos via TenantMaterialPreference.
model GlobalTrainingMaterial {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String   // SLIDES | PDF | VIDEO | INFOGRAFIA
  fileUrl     String
  fileSize    Int?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// ─── MODELOS TENANT — MÓDULO CORE ────────────────────────────────────────────
// Estos modelos se replican en la DB de cada tenant.
// Son obligatorios y siempre están presentes.

/// Usuario del sistema. Pertenece a un tenant específico.
/// La autenticación se hace contra la DB del tenant correspondiente.
model User {
  id           String   @id @default(cuid())
  tenantId     String
  name         String?  // Nombre completo (opcional para no romper registros existentes)
  email        String
  passwordHash String   // Nunca almacenar contraseña en texto plano
  role         UserRole
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@unique([tenantId, email])
}

/// Líder político. Estructura jerárquica autorreferenciada.
/// Un líder puede tener sub-líderes formando un árbol de comandos.
model Leader {
  id             String       @id @default(cuid())
  tenantId       String
  name           String
  // CIFRADO: campo PII — se cifra con AES-256 antes de persistir. Ver lib/crypto.ts
  phone          String?
  zone           String?      // Zona geográfica bajo su responsabilidad
  parentLeaderId String?      // Referencia al líder superior en la jerarquía
  targetVotes    Int          @default(0) // Meta de votos a conseguir
  status         LeaderStatus @default(ACTIVO)
  createdAt      DateTime     @default(now())

  parent   Leader?  @relation("JerarquiaLideres", fields: [parentLeaderId], references: [id])
  children Leader[] @relation("JerarquiaLideres")
  voters   Voter[]

  @@index([tenantId])
  @@index([tenantId, parentLeaderId])
}

/// Elector registrado en la campaña.
/// Los campos PII (cédula, teléfono) van cifrados en la capa de aplicación.
model Voter {
  id               String           @id @default(cuid())
  tenantId         String
  // CIFRADO: campo PII (número de cédula) — se cifra con AES-256 antes de persistir. Ver lib/crypto.ts
  cedula           String
  // SHA-256 de la cédula en texto plano. Permite deduplicación sin exponer el valor original.
  // Se calcula con: createHash('sha256').update(cedula.trim()).digest('hex')
  cedulaHash       String?
  name             String
  // CIFRADO: campo PII — se cifra con AES-256 antes de persistir. Ver lib/crypto.ts
  phone            String?
  address          String?          // Dirección física del elector
  leaderId         String?          // Líder responsable de este elector
  votingTableId    String?          // Mesa donde está inscrito
  commitmentStatus CommitmentStatus @default(SIN_CONTACTAR)
  lastContact      DateTime?        // Último contacto registrado
  notes            String?          // Notas del líder sobre el elector
  // Árbol de captación por referidos
  referredById     String?          // FK al Voter que refirió a esta persona
  captureDepth     Int              @default(0) // Nivel en el árbol de captación (0 = directo del líder)
  qrTokenUsed      String?          // Token del QR que usó para registrarse
  createdAt        DateTime         @default(now())

  leader      Leader?      @relation(fields: [leaderId], references: [id])
  votingTable VotingTable? @relation(fields: [votingTableId], references: [id])
  referredBy  Voter?       @relation("VoterReferrals", fields: [referredById], references: [id])
  referrals   Voter[]      @relation("VoterReferrals")

  // Un elector no puede estar duplicado dentro del mismo tenant (por cédula cifrada)
  @@unique([tenantId, cedula])
  // Deduplicación por SHA-256 de cédula — permite búsqueda rápida de duplicados
  @@unique([tenantId, cedulaHash])
  @@index([tenantId, leaderId])
  @@index([tenantId, commitmentStatus])
}

/// QR de captación generado por un líder. El token genera la URL pública de registro.
model QrRegistration {
  id                 String    @id @default(cuid())
  tenantId           String
  leaderId           String
  token              String    @unique  // crypto.randomUUID() — siempre generado en el servidor
  isActive           Boolean   @default(true)
  expiresAt          DateTime?           // null = sin vencimiento
  registrationsCount Int       @default(0) // Incrementa con cada registro exitoso
  createdAt          DateTime  @default(now())

  @@index([tenantId, leaderId])
  @@unique([tenantId, token])
}

/// Alerta de cédula duplicada entre dos líderes.
/// Nunca contiene la cédula en texto plano — solo su SHA-256.
model VoterDuplicateAlert {
  id                  String   @id @default(cuid())
  tenantId            String
  cedulaHash          String   // SHA-256 de la cédula — NUNCA la cédula en plano
  firstLeaderId       String   // Líder que la registró primero
  duplicateLeaderId   String   // Líder que intentó registrarla después
  status              String   @default("PENDIENTE") // PENDIENTE | REVISADA
  detectedAt          DateTime @default(now())

  @@index([tenantId, cedulaHash])
}

/// Notificación para un usuario del tenant.
model Notification {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  type      String   // DUPLICADO_ELECTOR | QR_REGISTRO | etc.
  message   String
  isRead    Boolean  @default(false)
  metadata  Json?    // Datos adicionales según el tipo
  createdAt DateTime @default(now())

  @@index([tenantId, userId, isRead])
}

// ─── ESTRUCTURA TERRITORIAL DIVIPOLA ─────────────────────────────────────────
// Jerarquía: Departamento → Municipio → Comuna/Corregimiento → Barrio/Vereda
// Los códigos DIVIPOLA son los oficiales del DANE de Colombia.

/// Departamento de Colombia. Código DIVIPOLA de 2 dígitos.
model Department {
  id   String @id @default(cuid())
  code String @unique // Ej: "05" para Antioquia
  name String          // Ej: "Antioquia"

  municipalities Municipality[]
}

/// Municipio con código DIVIPOLA. Unidad básica electoral en Colombia.
model Municipality {
  id           String @id @default(cuid())
  divipola     String @unique // Código de 5 dígitos. Ej: "05001" para Medellín
  name         String
  departmentId String

  department     Department      @relation(fields: [departmentId], references: [id])
  communes       Commune[]
  votingStations VotingStation[]
}

/// Comuna (zona urbana) o corregimiento (zona rural) dentro de un municipio.
model Commune {
  id             String      @id @default(cuid())
  name           String
  type           CommuneType // COMUNA o CORREGIMIENTO
  municipalityId String

  municipality  Municipality   @relation(fields: [municipalityId], references: [id])
  neighborhoods Neighborhood[]
}

/// Barrio (zona urbana) o vereda (zona rural) dentro de una comuna/corregimiento.
model Neighborhood {
  id        String @id @default(cuid())
  name      String
  communeId String

  commune Commune @relation(fields: [communeId], references: [id])
}

/// Puesto de votación. Lugar físico donde se instalan las mesas.
model VotingStation {
  id             String @id @default(cuid())
  name           String          // Ej: "Institución Educativa San José"
  address        String
  municipalityId String
  lat            Float? // Latitud para mapa de calor
  lng            Float? // Longitud para mapa de calor

  municipality Municipality  @relation(fields: [municipalityId], references: [id])
  tables       VotingTable[]
}

/// Mesa de votación dentro de un puesto. Unidad mínima del sistema electoral.
model VotingTable {
  id            String @id @default(cuid())
  number        Int    // Número de mesa dentro del puesto
  stationId     String
  voterCapacity Int    @default(0) // Capacidad máxima de electores por mesa

  station VotingStation @relation(fields: [stationId], references: [id])
  voters  Voter[]

  // No puede haber dos mesas con el mismo número en el mismo puesto
  @@unique([stationId, number])
}

// ─── MODELOS TENANT — MÓDULO ANALYTICS ───────────────────────────────────────
// Modelos específicos del módulo de Analítica e Inteligencia.

/// Análisis de fidelidad de un líder generado por el agente IA (Zhipu Flash).
/// Se cachea por 24 horas — si ya existe uno reciente, no se vuelve a llamar a la IA.
model LeaderAnalysis {
  id                String   @id @default(cuid())
  tenantId          String
  leaderId          String
  perfilTipo        String   // Leal | Oportunista | Transaccional | Maximizador | DesertorPotencial
  indiceFidelidad   Int      // 0-100
  indiceRiesgo      Int      // 0-100
  veredicto         String   // FIDELIZAR | MONITOREAR | PRESCINDIR
  planAccion        Json?    // null si veredicto es PRESCINDIR
  senalesDetectadas Json     // Array de { señal, peso: ALTO|MEDIO|BAJO }
  justificacion     String
  generadoEn        DateTime @default(now())

  @@index([tenantId, leaderId, generadoEn])
}

/// Configuración del tenant para el módulo de Analytics.
/// Almacena parámetros configurables por campaña: fechas, metas, históricos.
model TenantConfig {
  id                    String    @id @default(cuid())
  tenantId              String    @unique
  fechaEleccion         DateTime?
  metaVotos             Int?
  votosEleccionAnterior Int?
  updatedAt             DateTime  @updatedAt
}

// ─── MODELOS TENANT — MÓDULO FORMACIÓN ───────────────────────────────────────
// Modelos específicos del módulo de Formación y Capacitación.

/// Preferencia de un tenant sobre un material global de formación.
/// Permite ocultar materiales globales o cambiar su orden de presentación.
model TenantMaterialPreference {
  id               String  @id @default(cuid())
  tenantId         String
  globalMaterialId String  // Referencia al GlobalTrainingMaterial en la DB superadmin
  isHidden         Boolean @default(false)
  customOrder      Int?

  @@unique([tenantId, globalMaterialId])
}

/// Material de formación propio del tenant (subido por ADMIN_CAMPANA).
/// Se muestra DESPUÉS de los materiales globales en la vista del testigo.
model TrainingMaterial {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  description String?
  type        String   // SLIDES | PDF | VIDEO | INFOGRAFIA
  fileUrl     String   // URL de Vercel Blob o URL externa
  fileSize    Int?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([tenantId])
}

/// Sesión de capacitación programada por el admin del tenant.
model TrainingSession {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  description String?
  date        DateTime // Fecha y hora de la sesión
  location    String?  // Lugar físico o "Virtual"
  maxCapacity Int?     // null = sin límite
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  attendances TrainingAttendance[]

  @@index([tenantId])
}

/// Registro de asistencia a una sesión de capacitación.
model TrainingAttendance {
  id        String   @id @default(cuid())
  tenantId  String
  sessionId String
  userId    String   // Usuario que asistió (rol TESTIGO normalmente)
  attended  Boolean  @default(false) // Confirmado por el admin
  createdAt DateTime @default(now())

  session TrainingSession @relation(fields: [sessionId], references: [id])

  @@unique([sessionId, userId])
  @@index([tenantId, userId])
}

/// Evaluación / Quiz creado por el admin del tenant.
/// Las preguntas se almacenan en QuizQuestion.
model Quiz {
  id              String   @id @default(cuid())
  tenantId        String
  title           String
  description     String?
  passingScore    Int      @default(60) // Porcentaje mínimo para aprobar (0-100)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@index([tenantId])
}

/// Pregunta de un quiz. correctIndex NUNCA se envía al cliente.
/// El endpoint getQuizForUser excluye este campo explícitamente.
model QuizQuestion {
  id           String @id @default(cuid())
  quizId       String
  text         String           // Enunciado de la pregunta
  options      Json             // String[] con las opciones (4 típicamente)
  correctIndex Int              // Índice de la respuesta correcta (0-based)
  order        Int   @default(0)

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
}

/// Intento de un usuario en un quiz. Se permite múltiples intentos.
/// Las respuestas y el scoring se procesan server-side.
model QuizAttempt {
  id        String   @id @default(cuid())
  tenantId  String
  quizId    String
  userId    String
  answers   Json     // Int[] — índice seleccionado por pregunta (en orden)
  score     Int      // Porcentaje obtenido (0-100)
  passed    Boolean  // score >= quiz.passingScore
  createdAt DateTime @default(now())

  quiz Quiz @relation(fields: [quizId], references: [id])

  @@index([tenantId, userId])
  @@index([quizId, userId])
}

/// Certificado emitido a un testigo que aprobó una evaluación.
/// El PDF se genera con @react-pdf/renderer y se almacena en Vercel Blob.
model Certificate {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  quizId    String
  pdfUrl    String   // URL del PDF en Vercel Blob
  issuedAt  DateTime @default(now())

  @@unique([tenantId, userId, quizId])
  @@index([tenantId, userId])
}
