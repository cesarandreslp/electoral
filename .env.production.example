# ─── CampaignOS — variables de entorno PRODUCCIÓN (Vercel) ────────────────────
# Pegar cada par KEY=valor en Project Settings → Environment Variables.
# Marcar todas como "Production" (y "Preview" si querés que los preview deploys
# usen una DB de staging — para eso conviene un set distinto).
#
# Dejar VACÍA cualquier variable bloqueará el boot por la guarda en
# `apps/web/lib/assert-env.ts`. No hay forma de levantar el server malconfigurado.

# ─── Base de datos del superadmin (Neon) ──────────────────────────────────────
# La connection string del proyecto Neon "superadmin" (NO uno de tenant).
# Pooled, sslmode=require, channel_binding=require.
DATABASE_URL_SUPERADMIN=postgresql://neondb_owner:...@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DATABASE_URL=postgresql://neondb_owner:...@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ─── NextAuth v5 ──────────────────────────────────────────────────────────────
# Generar con: openssl rand -hex 32  (32+ chars).
NEXTAUTH_SECRET=
# Dominio canónico del panel superadmin. Ejemplo: https://admin.tu-dominio.co
NEXTAUTH_URL=https://admin.tu-dominio.co

# ─── Neon API ─────────────────────────────────────────────────────────────────
# Sin esta key, el provisioner cae al mock y la guarda runtime aborta en producción.
NEON_API_KEY=napi_...

# ─── Vercel Blob ──────────────────────────────────────────────────────────────
# Almacena fotos de actas E-14, materiales de formación, comprobantes financieros.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ─── Cifrado AES-256-GCM ──────────────────────────────────────────────────────
# Generar UNA SOLA VEZ con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CRÍTICO: rotar esta llave invalida TODOS los datos cifrados (cédulas, teléfonos,
# connection strings de tenants, donantes, tesoreros, mensajes). NUNCA la rotes
# sin un plan de re-encriptación.
ENCRYPTION_KEY=

# ─── Dominio base para resolución multi-tenant ────────────────────────────────
# El middleware mapea host → slug usando esta cadena.
# El punto inicial es OBLIGATORIO. Ejemplo: .tu-dominio.co
# Con esto, https://acme.tu-dominio.co → tenant slug "acme".
TENANT_BASE_DOMAIN=.tu-dominio.co

# ─── Agentes IA ───────────────────────────────────────────────────────────────
# Groq: análisis en tiempo real de actas E-14 (módulo DIA_E).
GROQ_API_KEY=gsk_...
# Zhipu Flash: análisis de fidelidad de líderes (módulo ANALYTICS).
ZHIPU_API_KEY=...

# ─── Rutas del monorepo (definidas en vercel.json) ────────────────────────────
# NO definir aquí — Vercel las inyecta desde vercel.json:
#   MONOREPO_ROOT
#   PRISMA_SCHEMA_PATH
