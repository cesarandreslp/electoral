# Base de datos del superadmin (Neon PostgreSQL)
DATABASE_URL_SUPERADMIN=

# Autenticación (NextAuth v5)
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# Neon API — para crear bases de datos de tenants programáticamente
NEON_API_KEY=

# Vercel Blob — almacenamiento de fotos de actas y materiales
BLOB_READ_WRITE_TOKEN=

# Agentes de IA
GROQ_API_KEY=
ZHIPU_API_KEY=

# Cifrado AES-256 — para connectionStrings y campos PII
# Generar con: openssl rand -hex 32
ENCRYPTION_KEY=
